# OBIE Configuration

# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────
APP_NAME=OBIE
APP_VERSION=2.0.0
ENV=development
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://obie:obie_password@localhost:5432/obie
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─────────────────────────────────────────────────────────────
# Redis (Celery)
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────────────────────────
# Celery
# ─────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_RESULT_SERIALIZER=json
CELERY_TIMEZONE=UTC

# ─────────────────────────────────────────────────────────────
# API Keys (Optional but recommended)
# ─────────────────────────────────────────────────────────────
GROQ_API_KEY=
# Get from: https://console.groq.com

# ─────────────────────────────────────────────────────────────
# Scoring Configuration
# ─────────────────────────────────────────────────────────────
# Default scoring profile weights (sum to 1.0)
SCORING_RECENCY_WEIGHT=0.25
SCORING_PRODUCT_FIT_WEIGHT=0.20
SCORING_DEMAND_SPECIFICITY_WEIGHT=0.20
SCORING_BUYER_RELIABILITY_WEIGHT=0.15
SCORING_CONTACTABILITY_WEIGHT=0.10
SCORING_URGENCY_WEIGHT=0.10

# Tier thresholds (0-100 scale)
SCORING_S_TIER_THRESHOLD=85
SCORING_A_TIER_THRESHOLD=70
SCORING_B_TIER_THRESHOLD=50

# ─────────────────────────────────────────────────────────────
# Dedupe Configuration
# ─────────────────────────────────────────────────────────────
# Fuzzy match threshold (0-1, higher = stricter)
DEDUPE_FUZZY_THRESHOLD=0.85
# Exact match fields
DEDUPE_EXACT_FIELDS=url,domain
# Fuzzy match fields
DEDUPE_FUZZY_FIELDS=buyer_name,product

# ─────────────────────────────────────────────────────────────
# Enrichment Configuration
# ─────────────────────────────────────────────────────────────
# Email verification mode: none, mx_only, smtp_safe
EMAIL_VERIFICATION_MODE=mx_only
# Max concurrent enrichment tasks
ENRICHMENT_MAX_CONCURRENT=10

# ─────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────
# Requests per minute per source
RATE_LIMIT_PER_MINUTE=60
# Delay between requests (seconds)
REQUEST_DELAY=1.0

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/obie.log

# ─────────────────────────────────────────────────────────────
# CORS (Frontend)
# ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type

# ─────────────────────────────────────────────────────────────
# Data Retention (days)
# ─────────────────────────────────────────────────────────────
DATA_RETENTION_DAYS=730
# Lead auto-archive after (days)
LEAD_AUTO_ARCHIVE_DAYS=90
